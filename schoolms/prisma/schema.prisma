// SchoolMS Prisma Schema
// Phase 1, Task 2 — Complete database layer

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  SUPERADMIN
  ADMIN
  STAFF
  TEACHER
  STUDENT
}

enum Term {
  TERM_1
  TERM_2
  TERM_3
}

enum MarksStatus {
  DRAFT
  PUBLISHED
}

enum NoticeStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

// ─── Embedded Types ──────────────────────────────────────

type Electives {
  categoryI   String
  categoryII  String
  categoryIII String
}

type Marks {
  sinhala     Int?
  buddhism    Int?
  maths       Int?
  science     Int?
  english     Int?
  history     Int?
  categoryI   Int?
  categoryII  Int?
  categoryIII Int?
}

// ─── Models ──────────────────────────────────────────────

model User {
  id                  String    @id @default(auto()) @map("_id") @db.ObjectId
  name                String
  email               String    @unique
  passwordHash        String
  role                Role      @default(STAFF)
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  sessionInvalidatedAt DateTime?
  // TEACHER role: the class group they are assigned to teach
  assignedClassId     String?   @db.ObjectId
  // STUDENT role: the linked student record for self-service login
  linkedStudentId     String?   @db.ObjectId

  @@map("users")
}

model ClassGroup {
  id       String    @id @default(auto()) @map("_id") @db.ObjectId
  grade    Int
  section  String
  students Student[]

  @@map("classGroups")
}

model Student {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  indexNumber       String?      @unique
  classId          String       @db.ObjectId
  class            ClassGroup   @relation(fields: [classId], references: [id])
  electives        Electives
  scholarshipMarks Int?
  markRecords      MarkRecord[]
  createdAt        DateTime     @default(now())
  isDeleted        Boolean      @default(false)

  @@index([classId])
  @@map("students")
}

model MarkRecord {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId String   @db.ObjectId
  student   Student  @relation(fields: [studentId], references: [id])
  term      Term
  year      Int
  marks     Marks
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  updatedBy String   @db.ObjectId

  @@unique([studentId, term, year])
  @@index([term, year])
  @@map("markRecords")
}

model SystemConfig {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("systemConfigs")
}

model AuditLog {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  timestamp       DateTime @default(now())
  userId          String?  @db.ObjectId
  userDisplayName String
  action          String
  targetId        String?  @db.ObjectId
  targetType      String?
  ipAddress       String?
  details         String

  @@index([timestamp(sort: Desc)])
  @@map("auditLogs")
}

model SecureSetting {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String   // AES-256-GCM encrypted: iv:authTag:ciphertext (base64)
  updatedAt DateTime @updatedAt

  @@map("secureSettings")
}

// Stores slide label overrides for a given medium (e.g. "sinhala")
model PresentationConfig {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique  // "sinhala" | "english"
  labels    Json     // Partial<Record<SlideLabelKey, string>>
  updatedAt DateTime @updatedAt

  @@map("presentationConfigs")
}

// Stores scheduled meetings/events for classes
model Meeting {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  classGroup  String   // e.g. "11B", "10C", "ALL"
  date        String   // ISO date "YYYY-MM-DD"
  startTime   String   // "HH:MM" 24-hour
  endTime     String?  // "HH:MM" optional
  description String?
  createdBy   String   // display name of creator
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@map("meetings")
}

// ─── Notification ─────────────────────────────────────────
model Notification {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  type        String   // e.g. "STUDENT_CREATED", "BACKUP_FAILED"
  title       String
  message     String
  targetRoles String[] // roles that see this notification
  data        Json?    // extra context (studentId, meetingId, etc.)
  createdBy   String?  // display name of the actor
  readBy      String[] // array of user IDs who've marked this as read

  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

// ─── Marks Release ────────────────────────────────────────
// Tracks whether a class's marks for a given term/year are DRAFT or PUBLISHED.
// PUBLISHED = visible to students; DRAFT = only visible to staff/admin.
model MarksRelease {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  classId   String      @db.ObjectId
  term      Term
  year      Int
  status    MarksStatus @default(DRAFT)
  changedBy String?     @db.ObjectId  // userId who last changed the status
  changedAt DateTime?

  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@unique([classId, term, year])
  @@index([classId])
  @@map("marksReleases")
}

// ─── Notice Board ─────────────────────────────────────────
// Public notices created by admins; published notices appear on the public
// notice board and push an in-app notification to the target roles.
model Notice {
  id          String       @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  content     String
  targetRoles String[]     // ["ALL"] or specific roles e.g. ["TEACHER", "STAFF"]
  status      NoticeStatus @default(DRAFT)
  publishedAt DateTime?
  expiresAt   DateTime?    // optional expiry date
  createdBy   String       // display name of author
  createdById String       @db.ObjectId
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([status, createdAt(sort: Desc)])
  @@map("notices")
}
