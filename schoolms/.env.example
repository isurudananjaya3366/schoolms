# MongoDB Atlas connection string (required for build)
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/schoolms"

# NextAuth.js secret for JWT signing (min 32 chars, required for build)
NEXTAUTH_SECRET="your-secret-key-at-least-32-characters-long"

# Canonical app URL (required in production)
NEXTAUTH_URL="http://localhost:3000"

# Vercel API token for programmatic env var writes (Phase 5)
VERCEL_API_TOKEN=""

# Vercel project identifier (Phase 5)
VERCEL_PROJECT_ID=""

# Shared secret for cron job authentication (Phase 5)
CRON_SECRET=""

# Resend email API key (Phase 2)
RESEND_API_KEY=""

# SMTP configuration fallback (Phase 3)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Upstash Redis for rate limiting (Phase 5)
UPSTASH_REDIS_REST_URL=""

# Vercel Blob storage token (Phase 3/5)
BLOB_READ_WRITE_TOKEN=""

# AWS S3 backup storage (Phase 5)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET=""

# Database configuration status flag (set to "true" after initial setup)
NEXT_PUBLIC_DB_CONFIGURED="false"
